import os
import requests
import dotenv

dotenv.load_dotenv()

# --- CONFIGURATION ---
API_KEY = os.getenv("BACKBOARD_API_KEY")
# Use the Assistant ID from your previous run
ASSISTANT_ID = "4e24ca63-63ba-4a62-ad83-e8e367748e5c" 
HEADERS = {"X-API-Key": API_KEY}
BASE_URL = "https://app.backboard.io/api"

def check_response(response, step_name):
    if response.status_code == 200:
        print(f"✅ {step_name} Success!")
        return response.json()
    else:
        print(f"❌ {step_name} Failed: {response.status_code} - {response.text}")
        return None

def main():
    # --- Step 1 & 2: Create a Thread and Send Message with Web Search & Memory ---
    # First, we need a thread
    thread_resp = requests.post(f"{BASE_URL}/threads", headers=HEADERS, json={"assistant_id": ASSISTANT_ID})
    thread = check_response(thread_resp, "Create Thread")
    if not thread: return
    thread_id = thread['thread_id']

    print("\n--- Testing Web Search & Memory ---")
    msg_data = {
        "content": "I prefer Python over JavaScript for backend development. Also, what is the current price of Bitcoin?",
        "web_search": "auto",
        "memory": "Auto",
        "stream": False
    }
    msg_resp = requests.post(f"{BASE_URL}/threads/{thread_id}/messages", headers=HEADERS, json=msg_data)
    check_response(msg_resp, "Send Message")

    # --- Step 3: List All Memories ---
    print("\n--- Listing Memories ---")
    list_resp = requests.get(f"{BASE_URL}/assistants/{ASSISTANT_ID}/memories", headers=HEADERS)
    mem_data = check_response(list_resp, "List Memories")
    
    if mem_data and mem_data.get("memories"):
        for mem in mem_data["memories"]:
            print(f"Found Memory: {mem['content']} (ID: {mem['id']})")
            
            # --- Step 5: Update a Memory (Using the first one found) ---
            mem_id = mem['id']
            print(f"\n--- Updating Memory {mem_id} ---")
            requests.put(
                f"{BASE_URL}/assistants/{ASSISTANT_ID}/memories/{mem_id}",
                headers=HEADERS,
                json={"content": "User is a CS student who prefers Python for backend."}
            )
            
            # --- Step 6: Delete a Memory ---
            # print(f"\n--- Deleting Memory {mem_id} ---")
            # requests.delete(f"{BASE_URL}/assistants/{ASSISTANT_ID}/memories/{mem_id}", headers=HEADERS)

    # --- Step 7: Check Memory Stats ---
    print("\n--- Checking Stats ---")
    stats_resp = requests.get(f"{BASE_URL}/assistants/{ASSISTANT_ID}/memories/stats", headers=HEADERS)
    stats = check_response(stats_resp, "Memory Stats")
    if stats:
        print(f"Total memories stored: {stats['total_count']}")

if __name__ == "__main__":
    main()